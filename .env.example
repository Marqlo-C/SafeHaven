# =============================================================================
# HOW TO USE THIS FILE
# =============================================================================
# 1. Copy this file:    cp .env.example .env
# 2. Fill in each value below using the instructions per section.
# 3. NEVER commit .env — it is already in .gitignore.
#    This .env.example IS committed so collaborators know what keys exist.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER (safe defaults — no changes needed for local dev)
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development
HOSTNAME=localhost

# The origin your frontend runs on. In production, set this to your domain.
# Prevents unauthorized sites from connecting to the Socket.io server.
ALLOWED_ORIGIN=http://localhost:3000


# -----------------------------------------------------------------------------
# MONGODB ATLAS
# -----------------------------------------------------------------------------
# HOW TO GET:
#   1. Go to https://cloud.mongodb.com and sign in (ask Lead for org invite).
#   2. Open the shared project → click "Connect" on the cluster.
#   3. Choose "Drivers" → copy the connection string.
#   4. Replace <user> and <password> with your Atlas DB user credentials.
#      (Create one under Database Access → Add New Database User)
#   5. Replace <dbname> with: hackdavis_dev
#
# FORMAT:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/hackdavis_dev?retryWrites=true&w=majority


# -----------------------------------------------------------------------------
# JWT (JSON Web Token secret)
# -----------------------------------------------------------------------------
# HOW TO GET:
#   Generate a cryptographically random string — do NOT invent one yourself.
#   Run this command in your terminal and paste the output here:
#
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
#   Every developer needs their OWN local value. The production secret is
#   stored only in the deployment environment (Vercel / Railway env vars).
#   If this secret leaks, all existing tokens become forgeable — rotate immediately.
JWT_SECRET=


# -----------------------------------------------------------------------------
# PWA — Panic exit destination
# -----------------------------------------------------------------------------
# HOW TO GET:
#   Pick any innocuous public URL — this is where the app redirects when a
#   survivor triggers the quick-exit (Escape key, triple-tap, or corner button).
#   Must be a full URL with https://. Default if unset: https://www.google.com
#
#   IMPORTANT: NEXT_PUBLIC_ prefix is required — this value is bundled into
#   the client-side JS by Next.js. Do NOT put secrets in NEXT_PUBLIC_ vars.
NEXT_PUBLIC_SAFE_EXIT_URL=https://www.google.com


# -----------------------------------------------------------------------------
# CLAUDE AI API (optional — only needed if working on AI features)
# -----------------------------------------------------------------------------
# HOW TO GET:
#   Ask the Lead for a key from the shared Anthropic workspace, OR
#   create a personal key at https://console.anthropic.com → API Keys.
#   Personal keys are fine for local dev; use the team key only in production.
CLAUDE_API_KEY=


# -----------------------------------------------------------------------------
# NEWSAPI.AI (optional — only needed for live news headlines)
# -----------------------------------------------------------------------------
# HOW TO GET:
#   1. Create a free account at https://newsapi.ai/
#   2. Copy your API key from the dashboard.
#   3. Keep this server-only. Do NOT prefix with NEXT_PUBLIC_.
NEWSAPI_AI_KEY=


# -----------------------------------------------------------------------------
# ELEVENLABS API (optional — speech-to-text and text-to-speech)
# -----------------------------------------------------------------------------
# HOW TO GET:
#   1. Create an account at https://elevenlabs.io/
#   2. Get your API key from Profile Settings.
ELEVENLABS_API_KEY=


# -----------------------------------------------------------------------------
# MAPBOX (optional — required for the Aid / nearby resources map)
# -----------------------------------------------------------------------------
# HOW TO GET:
#   1. Create an account at https://mapbox.com/
#   2. Copy your default public token from the Tokens page.
#   Note: NEXT_PUBLIC_ prefix means this is bundled into client JS. Do NOT
#   put secrets in NEXT_PUBLIC_ vars — Mapbox public tokens are safe here.
NEXT_PUBLIC_MAPBOX_TOKEN=
